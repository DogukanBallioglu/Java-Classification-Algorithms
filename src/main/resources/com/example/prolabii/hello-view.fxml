<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.prolabii.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Makine Öğrenmesi Sınıflandırma Analizi" />

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Button onAction="#onLoadDataClick" text="Veri Setini Yükle" />
        <Label fx:id="statusLabel" text="Veri bekleniyor..." textFill="#d32f2f" />
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label fx:id="kLabel" text="KNN (K Değeri):" />
        <TextField fx:id="kInput" prefWidth="50.0" text="5" />

        <Label fx:id="depthLabel" text="Karar Ağacı (Max Derinlik):" />
        <TextField fx:id="depthInput" prefWidth="50.0" text="5" />

        <Label text="Eğitim Oranı (0-1):" />
        <TextField fx:id="splitInput" prefWidth="50.0" text="0.8" />
    </HBox>



    <HBox alignment="CENTER" spacing="15.0">
        <Label text="Çalıştırılacak Model:" />
        <ComboBox fx:id="modelSelector" prefWidth="200.0" promptText="Model Seçiniz..." />
        <Button onAction="#onRunModelsClick" style="-fx-font-weight: bold; -fx-background-color: #4CAF50; -fx-text-fill: white;" text="Seçili Modeli Çalıştır" />
    </HBox>

    <TextArea fx:id="resultArea" VBox.vgrow="ALWAYS" wrapText="true" editable="false" prefHeight="120.0" promptText="Sonuçlar ve süreler burada görüntülenecek..." />

    <BarChart fx:id="accuracyChart" prefHeight="250.0" title="Model Doğruluk (Accuracy) Kıyaslaması">
        <xAxis>
            <CategoryAxis label="Modeller" />
        </xAxis>
        <yAxis>
            <NumberAxis autoRanging="false" label="Doğruluk (%)" lowerBound="0" tickUnit="10" upperBound="100" />
        </yAxis>
    </BarChart>
</VBox>